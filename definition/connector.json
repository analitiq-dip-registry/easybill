{
  "$schema": "https://schemas.analitiq.ai/connector/latest.json",
  "kind": "api",
  "connector_id": "easybill",
  "display_name": "EasyBill",
  "description": "EasyBill invoicing & accounting REST API — documents, customers, positions, payments and more.",
  "tags": ["api", "easybill", "invoicing", "accounting", "billing"],
  "documentation_url": "https://api.easybill.de/rest/v1/",
  "version": "0.0.0",
  "default_transport": "api",
  "transports": {
    "api": {
      "transport_type": "http",
      "base_url": "https://api.easybill.de/rest/v1",
      "headers": {
        "Accept": "application/json",
        "Content-Type": "application/json",
        "Authorization": { "template": "Bearer ${secrets.api_key}" }
      },
      "timeout_seconds": 30,
      "rate_limit": { "max_requests": 10, "time_window_seconds": 60 }
    }
  },
  "auth": { "type": "api_key" },
  "connection_contract": {
    "inputs": {
      "api_key": {
        "source": "user",
        "phase": "auth",
        "storage": "secrets",
        "type": "string",
        "required": true,
        "secret": true,
        "ui": {
          "label": "API Key",
          "widget": "password",
          "help_text": "Your easybill REST API key. Generate it in the easybill app under Settings → API. Sent as an 'Authorization: Bearer <api_key>' header on every request."
        }
      }
    },
    "required_for_activation": ["secrets.api_key"]
  }
}
