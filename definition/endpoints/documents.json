{
  "$schema": "https://schemas.analitiq.ai/api-endpoint/latest.json",
  "endpoint_id": "documents",
  "display_name": "Invoices",
  "description": "Invoices, offers, credit notes and other documents",
  "operations": {
    "read": {
      "request": {
        "method": "GET",
        "path": "/documents",
        "transport_ref": "api"
      },
      "params": {
        "page": {
          "in": "query",
          "type": "integer",
          "required": false,
          "default": {
            "literal": 1
          },
          "controlled_by": "pagination",
          "description": "1-based page number (pagination cursor)."
        },
        "limit": {
          "in": "query",
          "type": "integer",
          "required": false,
          "default": {
            "literal": 1000
          },
          "controlled_by": "pagination",
          "description": "Page size. Default 100, max 1000."
        },
        "type": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter documents by type. Multiple typs seperate with , like type=INVOICE,CREDIT"
        },
        "is_draft": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq"
          ],
          "description": "Filter documents by draft flag."
        },
        "is_archive": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq"
          ],
          "description": "Filter documents by archive flag."
        },
        "customer_id": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter documents by customer_id. You can add multiple customer_is separate by co"
        },
        "project_id": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter documents by project_id. You can add multiple project_id separate by comm"
        },
        "ref_id": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter documents by ref_id."
        },
        "document_date": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "gte",
            "lte"
          ],
          "description": "Filter documents by document_date. You can filter one date with document_date=20"
        },
        "paid_at": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "gte",
            "lte"
          ],
          "description": "Filter documents by paid_at. You can filter one date with paid_at=2014-12-10 or "
        },
        "title": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter documents by title."
        },
        "number": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter documents by number."
        },
        "cancel_id": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter documents by cancel_id. You can add multiple ids separate by comma like i"
        },
        "fulfillment_country": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter documents by fulfillment_country."
        },
        "vat_country": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter documents by vat_country."
        },
        "shipping_country": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter documents by shipping_country."
        },
        "status": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter documents by status. Keep in mind that not every document type has a stat"
        },
        "edited_at": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "gte",
            "lte"
          ],
          "description": "Filter documents by edited_at. You can filter one date with edited_at=2014-12-10",
          "controlled_by": "replication"
        }
      },
      "pagination": {
        "type": "page",
        "page": {
          "param": "page",
          "initial": 1,
          "increment_by": 1
        },
        "limit": {
          "param": "limit",
          "default": 1000,
          "max": 1000
        },
        "stop_when": {
          "empty": {
            "ref": "response.body.items"
          }
        }
      },
      "response": {
        "records": {
          "ref": "response.body.items"
        },
        "schema": {
          "type": "object",
          "properties": {
            "page": {
              "type": "integer"
            },
            "pages": {
              "type": "integer"
            },
            "limit": {
              "type": "integer"
            },
            "total": {
              "type": "integer"
            },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "address": {
                    "type": "object",
                    "native_type": "object",
                    "arrow_type": "Json"
                  },
                  "advanced_data_fields": {
                    "type": "array",
                    "native_type": "array",
                    "arrow_type": "Json",
                    "description": "EN16931 Business Terms (BT fields) for structured invoice data. On update the submitted list fully replaces the existing"
                  },
                  "attachment_ids": {
                    "type": "array",
                    "native_type": "array",
                    "arrow_type": "Json"
                  },
                  "label_address": {
                    "type": "object",
                    "native_type": "object",
                    "arrow_type": "Json"
                  },
                  "amount": {
                    "type": "integer",
                    "native_type": "integer",
                    "arrow_type": "Int64",
                    "description": "Amount in cents  (e.g. \"150\" = 1.50\u20ac)"
                  },
                  "amount_net": {
                    "type": "integer",
                    "native_type": "integer",
                    "arrow_type": "Int64",
                    "description": "Amount in cents  (e.g. \"150\" = 1.50\u20ac)"
                  },
                  "anonymize_due_date": {
                    "type": "string",
                    "native_type": "string:date",
                    "arrow_type": "Date32",
                    "description": "A date which signals when to anonymize the document. Must be in the future. Turns into a read only field if the document"
                  },
                  "anonymize_status": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8",
                    "description": "This field signals if the document was anonymized"
                  },
                  "anonymized_at": {
                    "type": "string",
                    "native_type": "string:datetime",
                    "arrow_type": "Timestamp(MICROSECOND, UTC)"
                  },
                  "bank_debit_form": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "billing_country": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "calc_vat_from": {
                    "type": "integer",
                    "native_type": "integer",
                    "arrow_type": "Int64",
                    "description": "0 === Net, 1 === Gross."
                  },
                  "cancel_id": {
                    "type": "integer",
                    "native_type": "integer:int64",
                    "arrow_type": "Int64",
                    "description": "ID from the cancel document. Only for document type INVOICE."
                  },
                  "cash_allowance": {
                    "type": "number",
                    "native_type": "number:float",
                    "arrow_type": "Float64",
                    "description": "Cash allowance percentage. If not provided, inherits from customer when available."
                  },
                  "cash_allowance_days": {
                    "type": "integer",
                    "native_type": "integer",
                    "arrow_type": "Int64",
                    "description": "Days for cash allowance. If not provided, inherits from customer when available."
                  },
                  "cash_allowance_text": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "contact_id": {
                    "type": "integer",
                    "native_type": "integer:int64",
                    "arrow_type": "Int64"
                  },
                  "contact_label": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "contact_text": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "created_at": {
                    "type": "string",
                    "native_type": "string:date-time",
                    "arrow_type": "Timestamp(MICROSECOND, UTC)"
                  },
                  "currency": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "customer_id": {
                    "type": "integer",
                    "native_type": "integer:int64",
                    "arrow_type": "Int64"
                  },
                  "customer_snapshot": {
                    "type": "object",
                    "native_type": "object",
                    "arrow_type": "Json"
                  },
                  "discount": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "discount_type": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "document_date": {
                    "type": "string",
                    "native_type": "string:date",
                    "arrow_type": "Date32"
                  },
                  "due_date": {
                    "type": "string",
                    "native_type": "string:date",
                    "arrow_type": "Date32",
                    "description": "To change the value use grace_period."
                  },
                  "edited_at": {
                    "type": "string",
                    "native_type": "string:date-time",
                    "arrow_type": "Timestamp(MICROSECOND, UTC)"
                  },
                  "external_id": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "replica_url": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "grace_period": {
                    "type": "integer",
                    "native_type": "integer",
                    "arrow_type": "Int64",
                    "description": "will be replaced by its alias due_in_days."
                  },
                  "due_in_days": {
                    "type": "integer",
                    "native_type": "integer",
                    "arrow_type": "Int64",
                    "description": "due date in days. If not provided, inherits from customer when available"
                  },
                  "id": {
                    "type": "integer",
                    "native_type": "integer:int64",
                    "arrow_type": "Int64"
                  },
                  "is_acceptable_on_public_domain": {
                    "type": "boolean",
                    "native_type": "boolean",
                    "arrow_type": "Boolean",
                    "description": "Indicates if a document can be accepted by the end customer through the document's public access page."
                  },
                  "is_archive": {
                    "type": "boolean",
                    "native_type": "boolean",
                    "arrow_type": "Boolean"
                  },
                  "is_draft": {
                    "type": "boolean",
                    "native_type": "boolean",
                    "arrow_type": "Boolean",
                    "description": "This property is read only. To finish the document call /documents/{id}/done."
                  },
                  "is_replica": {
                    "type": "boolean",
                    "native_type": "boolean",
                    "arrow_type": "Boolean",
                    "description": "Marks a document as a replica from another software."
                  },
                  "is_oss": {
                    "type": "boolean",
                    "native_type": "boolean",
                    "arrow_type": "Boolean",
                    "description": "Indicates if a document is a one-stop-shop document"
                  },
                  "item_notes": {
                    "type": "array",
                    "native_type": "array",
                    "arrow_type": "Json",
                    "description": "Field holds all unique document_note of items for the document"
                  },
                  "items": {
                    "type": "array",
                    "native_type": "array",
                    "arrow_type": "Json"
                  },
                  "last_postbox_id": {
                    "type": "integer",
                    "native_type": "integer:int64",
                    "arrow_type": "Int64"
                  },
                  "login_id": {
                    "type": "integer",
                    "native_type": "integer:int64",
                    "arrow_type": "Int64",
                    "description": "If omitted or null, the currently active login is used."
                  },
                  "number": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "order_number": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "buyer_reference": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "paid_amount": {
                    "type": "integer",
                    "native_type": "integer",
                    "arrow_type": "Int64"
                  },
                  "paid_at": {
                    "type": "string",
                    "native_type": "string:date",
                    "arrow_type": "Date32"
                  },
                  "pdf_pages": {
                    "type": "integer",
                    "native_type": "integer",
                    "arrow_type": "Int64"
                  },
                  "pdf_template": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8",
                    "description": "Default template is null or 'DE', default english is 'EN' and for all others use the numeric template ID."
                  },
                  "payment_link_enabled": {
                    "type": "boolean",
                    "native_type": "boolean",
                    "arrow_type": "Boolean",
                    "description": "Whether the payment link is shown on this document. Overrides the setting from the referenced template."
                  },
                  "payment_link_locale": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8",
                    "description": "Language of the payment link text on the document."
                  },
                  "project_id": {
                    "type": "integer",
                    "native_type": "integer",
                    "arrow_type": "Int64"
                  },
                  "recurring_options": {
                    "type": "object",
                    "native_type": "object",
                    "arrow_type": "Json"
                  },
                  "ref_id": {
                    "type": "integer",
                    "native_type": "integer:int64",
                    "arrow_type": "Int64",
                    "description": "Reference document id"
                  },
                  "root_id": {
                    "type": "integer",
                    "native_type": "integer:int64",
                    "arrow_type": "Int64",
                    "description": "Root document id"
                  },
                  "service_date": {
                    "type": "object",
                    "native_type": "object",
                    "arrow_type": "Json"
                  },
                  "shipping_country": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "status": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8",
                    "description": "This value can only be used in document type DELIVERY, ORDER, CHARGE or OFFER. NULL is default = not set."
                  },
                  "text": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "text_prefix": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "text_tax": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8",
                    "description": "Overwrites the default vat-option text from the document layout. It is only displayed in documents with the type other t"
                  },
                  "title": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "type": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8",
                    "description": "Can only set on create."
                  },
                  "use_shipping_address": {
                    "type": "boolean",
                    "native_type": "boolean",
                    "arrow_type": "Boolean",
                    "description": "If true and customer has shipping address then it will be used."
                  },
                  "vat_country": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "vat_id": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "fulfillment_country": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8"
                  },
                  "vat_option": {
                    "type": "string",
                    "native_type": "string",
                    "arrow_type": "Utf8",
                    "description": "NULL: Normal steuerbar<br/> nStb: Nicht steuerbar (Drittland)<br/> nStbUstID: Nicht steuerbar (EU mit USt-IdNr.)<br/> nS"
                  },
                  "file_format_config": {
                    "type": "array",
                    "native_type": "array",
                    "arrow_type": "Json"
                  }
                }
              }
            }
          }
        }
      },
      "replication": {
        "supported_methods": [
          "full_refresh",
          "incremental"
        ],
        "cursor_mappings": [
          {
            "cursor_field": "edited_at",
            "param": "edited_at",
            "operator": "gte",
            "format": "date-time"
          }
        ]
      }
    }
  }
}
