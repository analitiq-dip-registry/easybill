{
  "$schema": "https://schemas.analitiq.ai/api-endpoint/latest.json",
  "endpoint_id": "discounts-position",
  "display_name": "Position discounts",
  "description": "Position discounts",
  "operations": {
    "read": {
      "request": {
        "method": "GET",
        "path": "/discounts/position",
        "transport_ref": "api"
      },
      "params": {
        "page": {
          "in": "query",
          "type": "integer",
          "required": false,
          "default": {
            "literal": 1
          },
          "controlled_by": "pagination",
          "description": "1-based page number (pagination cursor)."
        },
        "limit": {
          "in": "query",
          "type": "integer",
          "required": false,
          "default": {
            "literal": 1000
          },
          "controlled_by": "pagination",
          "description": "Page size. Default 100, max 1000."
        },
        "customer_id": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter discounts by customer_id. You can add multiple customer_ids separate by c"
        }
      },
      "pagination": {
        "type": "page",
        "page": {
          "param": "page",
          "initial": 1,
          "increment_by": 1
        },
        "limit": {
          "param": "limit",
          "default": 1000,
          "max": 1000
        },
        "stop_when": {
          "empty": {
            "ref": "response.body.items"
          }
        }
      },
      "response": {
        "records": {
          "ref": "response.body.items"
        },
        "schema": {
          "type": "object",
          "properties": {
            "page": {
              "type": "integer"
            },
            "pages": {
              "type": "integer"
            },
            "limit": {
              "type": "integer"
            },
            "total": {
              "type": "integer"
            },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "position_id": {
                    "type": "integer",
                    "native_type": "integer:int64",
                    "arrow_type": "Int64"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
