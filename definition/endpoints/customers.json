{
  "$schema": "https://schemas.analitiq.ai/api-endpoint/latest.json",
  "endpoint_id": "customers",
  "display_name": "Customers / clients",
  "description": "Customers / clients",
  "operations": {
    "read": {
      "request": {
        "method": "GET",
        "path": "/customers",
        "transport_ref": "api"
      },
      "params": {
        "page": {
          "in": "query",
          "type": "integer",
          "required": false,
          "default": {
            "literal": 1
          },
          "controlled_by": "pagination",
          "description": "1-based page number (pagination cursor)."
        },
        "limit": {
          "in": "query",
          "type": "integer",
          "required": false,
          "default": {
            "literal": 1000
          },
          "controlled_by": "pagination",
          "description": "Page size. Default 100, max 1000."
        },
        "group_id": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter customers by group_id. You can add multiple group ids separate by comma l"
        },
        "additional_group_id": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter customers by additional_group_id. You can add multiple group ids separate"
        },
        "number": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter customers by number. You can add multiple numbers separate by comma like "
        },
        "country": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter customers by country. You can add multiple countries separate by comma li"
        },
        "zip_code": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter customers by zip_code. You can add multiple zip codes separate by comma l"
        },
        "emails": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter customers by emails. You can add multiple emails separate by comma like m"
        },
        "first_name": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter customers by first_name. You can add multiple names separate by comma lik"
        },
        "last_name": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter customers by first_name. You can add multiple names separate by comma lik"
        },
        "company_name": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "in"
          ],
          "description": "Filter customers by first_name. You can add multiple names separate by comma lik"
        },
        "created_at": {
          "in": "query",
          "type": "string",
          "required": false,
          "operators": [
            "eq",
            "gte",
            "lte"
          ],
          "description": "Filter customers by created_at. You can filter one date with created_at=2014-12-"
        }
      },
